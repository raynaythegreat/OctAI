FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/octai /usr/local/bin/octai
COPY $TARGETPLATFORM/aibhq-launcher /usr/local/bin/aibhq-launcher

RUN addgroup -g 1000 octai && \
    adduser -D -u 1000 -G octai octai

USER octai

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -q --spider http://localhost:18800/health || exit 1

ENTRYPOINT ["aibhq-launcher"]
CMD ["-public", "-no-browser"]
